{
  "version": 1,
  "cli": {
    "binary": "forge",
    "package": "forge-next"
  },
  "commands": [
    {
      "id": "forge:evaluate",
      "cli_subcommand": "evaluate",
      "description": "Plan review (pre) or implementation audit (post). Use code-review for full-team review.",
      "examples": [
        "forge evaluate --step 1 --mode pre --plan \"<plan keywords or path>\"",
        "forge evaluate --repo \"<path>\" --step 1 --mode post --plan \"<plan>\""
      ]
    },
    {
      "id": "forge:sketch",
      "cli_subcommand": "sketch",
      "description": "Organize intent and open decisions before design (optional CONTEXT.md/ADRs).",
      "examples": [
        "forge sketch --step 1",
        "forge sketch --step 1 --with-domain-docs"
      ]
    },
    {
      "id": "forge:design",
      "cli_subcommand": "design",
      "description": "Investigate, brainstorm solutions, and write a named design spec at docs/forge/specs/ (medium/large).",
      "examples": [
        "forge design --step 1",
        "forge design --step 1 --quick"
      ]
    },
    {
      "id": "forge:plan",
      "cli_subcommand": "plan",
      "description": "Create an implementation plan.",
      "examples": [
        "forge plan --step 1",
        "forge plan --repo \"<path>\" --step 1 --quick"
      ]
    },
    {
      "id": "forge:implement",
      "cli_subcommand": "implement",
      "description": "Execute an implementation plan in waves.",
      "examples": [
        "forge implement --step 1",
        "forge implement --step 3 --state \"<state path>\""
      ]
    },
    {
      "id": "forge:code-review",
      "cli_subcommand": "code-review",
      "description": "Run structured code review workflows.",
      "examples": [
        "forge code-review --step 1",
        "forge code-review --step 1 --quick"
      ]
    },
    {
      "id": "forge:test",
      "cli_subcommand": "test",
      "description": "Run tests or author mock flows (run/flows modes).",
      "examples": [
        "forge test --step 1",
        "forge test --mode flows --step 1"
      ]
    },
    {
      "id": "forge:diagnose",
      "cli_subcommand": "diagnose",
      "description": "Deep diagnosis workflow for bugs/regressions.",
      "examples": [
        "forge diagnose --step 1",
        "forge diagnose --step 1 --quick"
      ]
    },
    {
      "id": "forge:takeover",
      "cli_subcommand": "takeover",
      "description": "Infer work and drive Forge skills until ship-ready (replaces resume/iterate).",
      "examples": [
        "forge takeover",
        "forge takeover --design docs/forge/specs/2026-06-20-feature-design.md",
        "forge takeover --issue 42",
        "forge takeover --cleanup --force"
      ]
    },
    {
      "id": "forge:status",
      "cli_subcommand": "status",
      "description": "Show a lightweight workflow dashboard for a repo.",
      "examples": [
        "forge status",
        "forge status --repo \"<path>\""
      ]
    },
    {
      "id": "forge:doctor",
      "cli_subcommand": "doctor",
      "description": "Diagnose installation/PATH/encoding/runtime-root issues.",
      "examples": [
        "forge doctor",
        "forge doctor --repo \"<path>\""
      ]
    },
    {
      "id": "forge:graphify",
      "cli_subcommand": "graphify",
      "description": "Optional Graphify index: refresh status for forge takeover; install or remove a fail-soft post-commit hook.",
      "examples": [
        "forge graphify refresh",
        "forge graphify refresh --repo \"<path>\"",
        "forge graphify install-hook",
        "forge graphify install-hook --repo \"<path>\"",
        "forge graphify uninstall-hook"
      ]
    },
    {
      "id": "forge:ship",
      "cli_subcommand": "ship",
      "description": "Finalize work: commit, push, PR, merge, and publish release artifacts.",
      "examples": [
        "forge ship --step 1",
        "forge ship"
      ]
    }
  ]
}

